<div class="container">
    <h1><%= @flat.name %></h1>
    <h5><%= @flat.address %></h5>

    <div>
        <h3>A bit more about this flat...</h3>
        <p><%= @flat.description %></p>
        
        <% @flat.reviews.each do |review| %>
            <p><%= review.content %></p>
            <p><%= '⭐' * review.rating %></p>
        <% end %>
    </div>

    <div>
        <h4>Book This Place!</h4>
   </div>

   <div>
        <h3>Details</h3>
        <p><%= @flat.number_of_guests %></p>
        <p><%= @flat.price_per_night %></p>
   </div>
    <%= link_to  "Leave a Review", new_flat_review_path(@flat) %> |
    <%= link_to  "Back", root_path %>
</div>